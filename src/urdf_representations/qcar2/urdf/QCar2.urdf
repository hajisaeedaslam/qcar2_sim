<?xml version="1.0" ?>
<robot name="qcar2" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================= Materials ========================= -->
    <material name="Black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>
    <material name="Grey">
        <color rgba="0.1 0.1 0.1 1.0"/>
    </material>
    <material name="DarkGrey">
        <color rgba="0.06 0.06 0.06 1.0"/>
    </material>
    <material name="Red">
        <color rgba="0.8 0.0 0.0 1.0"/>
    </material>
    <material name="White">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>
    
<!--
    ###################################################################################################################
    The mass and inertial values for the base link of the QCar 2 have been updated to match the real robot.
    ###################################################################################################################
-->
<!--
    Uncomment this if you want the robot to be anchored to the world frame/ground plane.
    <link name="world"/>
    <joint name="world_base_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="world"/>
        <child link="base_link"/>
    </joint>
-->

  <!-- ========================= Base Links ========================= -->

    <link name="base_link">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file:///home/hajisaeed/qcar2_sim/install/qcar2/share/qcar2/meshes/QCar2Body.stl"
                scale="0.1 0.1 0.1"/>
            </geometry>
            <material name="Grey"/>
        </visual>

        <collision name="collision_center">
            <origin xyz="0.000 0 .053" rpy="0 0 0"/>
            <geometry>
                <box size=".155 .15 .08"/>
            </geometry>
        </collision>

        <collision name="collision_front">
            <origin xyz="0.194 0 .083" rpy="0 0 0"/>
            <geometry>
                <box size=".03 .15 .115"/>
            </geometry>
        </collision>

        <collision name="collision_back">
            <origin xyz="-0.183 0 .083" rpy="0 0 0"/>
            <geometry>
                <box size=".037 .15 .115"/>
            </geometry>
        </collision>

        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="3.275"/>
            <inertia ixx="0.01235" ixy="0" ixz="0" iyy="0.0292" iyz="0" izz="0.03223"/>
        </inertial>
    </link>

  <!-- ========================= Sensors ========================= -->

    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar"/>
        <origin rpy="0 0 0" xyz="-0.0139 0 .194"/>
        <axis xyz="0 0 1"/>
    </joint>
    <link name="lidar">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 -0.01"/>
            <geometry>
                <mesh filename="file:///home/hajisaeed/qcar2_sim/install/qcar2/share/qcar2/meshes/QCar2Lidar.stl" 
                scale="0.1 0.1 0.1"/>
            </geometry>
            <material name="Black"/>
        </visual>
        <visual>
            <origin rpy="0 0 0" xyz="-0.0003 -0.0004 -0.021"/>
            <geometry>
                <cylinder radius="0.04" length="0.0194"/>
            </geometry>
            <material name="Black"/>
        </visual>
            
    </link>

    <joint name="realsenseRGB_joint" type="fixed">
        <parent link="base_link"/>
        <child link="realsenseRGB"/>
        <origin rpy="-1.5708 0 -1.5708" xyz="0.095 0.034 0.176"/>
    </joint>
    <link name="realsenseRGB">
    </link>

    <joint name="realsenseDepth_joint" type="fixed">
        <parent link="base_link"/>
        <child link="realsenseDepth"/>
        <origin rpy="-1.5708 0 -1.5708" xyz="0.095 -0.003 0.176"/>
    </joint>
    <link name="realsenseDepth">
    </link>

    <joint name="csi_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="csi_front"/>
        <origin rpy="0 0 0" xyz="0.198 0 0.1095"/>
    </joint>
    <link name="csi_front">
        <inertial>
            <mass value="0.01"/>
            <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
        </inertial>
        <visual>
            <geometry>
                <box size="0.02 0.02 0.02"/>
            </geometry>
            <material name="Black"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.02 0.02 0.02"/>
            </geometry>
        </collision>
    </link>

    <joint name="csi_back_joint" type="fixed">
        <parent link="base_link"/>
        <child link="csi_back"/>
        <origin rpy="-1.5708 0 1.5708" xyz="-0.165 -0.0005 0.1095"/>
    </joint>
    <link name="csi_back">
    </link>

    <joint name="csi_right_joint" type="fixed">
        <parent link="base_link"/>
        <child link="csi_right"/>
        <origin rpy="-1.5708 0 3.14159" xyz="0.0155 -0.072 0.1095"/>
    </joint>
    <link name="csi_right">
    </link>

    <joint name="csi_left_joint" type="fixed">
        <parent link="base_link"/>
        <child link="csi_left"/>
        <origin rpy="-1.5708 0 0" xyz="0.0155 0.051 0.1095"/>
    </joint>
    <link name="csi_left">
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu"/>
        <origin rpy="0 0 0" xyz="0.0119 0 0.0896"/>
    </joint>
    <link name="imu">
    </link>


  <!-- ========================= Wheels ========================= -->

  <!--  Front Left  -->

    <joint name="hub_frontLeft_joint" type="revolute">
        <parent link="base_link"/>
        <child link="hub_frontLeft"/>
        <origin rpy="0 0 0" xyz="0.12960 0.05590 0.03338"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.5236" upper="0.5236" effort="300" velocity="2"/>
    </joint>
    <link name="hub_frontLeft">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file:///home/hajisaeed/qcar2_sim/install/qcar2/share/qcar2/meshes/QCarSteeringHubL.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="Black"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="wheel_frontLeft_joint" type="continuous">
        <parent link="hub_frontLeft"/>
        <child link="wheel_frontLeft"/>
        <origin rpy="-1.5708 0 0" xyz="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>
    <link name="wheel_frontLeft">
        <visual>
            <origin rpy="-1.5708 0 3.14159" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file:///home/hajisaeed/qcar2_sim/install/qcar2/share/qcar2/meshes/QCarWheel.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="Black"/>
        </visual>
        
        <collision>
            <origin xyz="0 0 0.022" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.033" length="0.025"/>
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

  <!--  Front Right  -->

    <joint name="hub_frontRight_joint"  type="revolute">
        <parent link="base_link"/>
        <child link="hub_frontRight"/>
        <origin rpy="0 0 0" xyz="0.12960 -0.05590 0.03338"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.5236" upper="0.5236" effort="300" velocity="2"/>
    </joint>
    <link name="hub_frontRight">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file:///home/hajisaeed/qcar2_sim/install/qcar2/share/qcar2/meshes/QCarSteeringHubR.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="Black"/>
        </visual>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>
    
    <joint name="wheel_frontRight_joint" type="continuous">
        <parent link="hub_frontRight"/>
        <child link="wheel_frontRight"/>
        <origin rpy="-1.5708 0 0" xyz="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>
    <link name="wheel_frontRight">
        <visual>
            <origin rpy="1.5708 0 3.14159" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file:///home/hajisaeed/qcar2_sim/install/qcar2/share/qcar2/meshes/QCarWheel.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="Black"/>
        </visual>
        <collision>
            <origin xyz="0 0 -0.022" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.033" length="0.025"/>
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

  <!--  Rear  -->

    <joint name="wheel_rearLeft_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_rearLeft"/>
        <origin rpy="-1.5708 0 0" xyz="-0.12765 0.05610 0.03338"/>
        <axis xyz="0 0 1"/>
        <!--<limit effort="10" velocity="100" />  added from f110 -->
    </joint>
    <link name="wheel_rearLeft">
        <visual>
            <origin rpy="-1.5708 0 3.14159" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file:///home/hajisaeed/qcar2_sim/install/qcar2/share/qcar2/meshes/QCarWheel.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="Black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.022" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.033" length="0.025"/>
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="wheel_rearRight_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_rearRight"/>
        <origin rpy="-1.5708 0 0" xyz="-0.12765 -0.05610 0.03338"/>
        <axis xyz="0 0 1"/>
    </joint>
    <link name="wheel_rearRight">
        <visual>
            <origin rpy="1.5708 0 3.14159" xyz="0 0 0"/>    
            <geometry>
                <mesh filename="file:///home/hajisaeed/qcar2_sim/install/qcar2/share/qcar2/meshes/QCarWheel.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="Black"/>
        </visual>
        <collision>
            <origin xyz="0 0 -0.022" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.033" length="0.025"/>
            </geometry>
        </collision>
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>
    

    <!-- ======================= Gazebo References ======================= -->
<!--
    <gazebo>
        <plugin filename="libgazebo_ros_control.so" name="gazebo_ros_control">
            <robotNamespace>/QCar</robotNamespace>
        </plugin>
    </gazebo>
-->

    <gazebo reference="base_link">
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    <gazebo reference="lidar">
        <material>Gazebo/Grey</material>
    </gazebo>
    <gazebo reference="hub_frontLeft">
        <material>Gazebo/Grey</material>
    </gazebo>
    <gazebo reference="hub_frontRight">
        <material>Gazebo/Grey</material>
    </gazebo>
    <gazebo reference="wheel_frontLeft">
        <material>Gazebo/Black</material>
    </gazebo>
    <gazebo reference="wheel_frontRight">
        <material>Gazebo/Black</material>
    </gazebo>
    <gazebo reference="wheel_rearLeft">
        <material>Gazebo/Black</material>
    </gazebo>
    <gazebo reference="wheel_rearRight">
        <material>Gazebo/Black</material>
    </gazebo>

<gazebo>
  <plugin
    filename="gz-sim-diff-drive-system"
    name="gz::sim::systems::DiffDrive">
    <left_joint>wheel_rearLeft_joint</left_joint>
    <right_joint>wheel_rearRight_joint</right_joint>
    <wheels_separation>0.112</wheels_separation>
    <wheels_radius>0.033</wheels_radius>
    <odom_publish_frequency>50</odom_publish_frequency>
    <topic>/model/qcar2/cmd_vel</topic>
  </plugin>
</gazebo>

<gazebo>
  <plugin filename="gz-sim-joint-state-publisher-system"
          name="gz::sim::systems::JointStatePublisher">
    <topic>/qcar2/joint_states</topic>
    <joint_name>hub_frontLeft_joint</joint_name>
    <joint_name>hub_frontRight_joint</joint_name>
    <joint_name>wheel_frontLeft_joint</joint_name>
    <joint_name>wheel_frontRight_joint</joint_name>
    <joint_name>wheel_rearLeft_joint</joint_name>
    <joint_name>wheel_rearRight_joint</joint_name>
  </plugin>
</gazebo>

<!-- LiDAR sensor on lidar link (top of chassis) -->
<gazebo reference="lidar">
  <sensor name="gpu_lidar" type="gpu_lidar">
    <topic>/qcar2/lidar/scan</topic>
    <update_rate>10</update_rate>
    <lidar>
      <scan>
        <horizontal>
          <samples>360</samples>
          <resolution>1</resolution>
          <min_angle>-3.14159265</min_angle>
          <max_angle>3.14159265</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.08</min>
        <max>12.0</max>
        <resolution>0.01</resolution>
      </range>
      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.01</stddev>
      </noise>
    </lidar>
    <always_on>true</always_on>
    <visualize>true</visualize>
  </sensor>
</gazebo>

<!-- Front-facing RGB camera on csi_front link -->
<gazebo reference="csi_front">
  <sensor name="front_camera" type="camera">
    <topic>/qcar2/front_camera/image</topic>
    <update_rate>30</update_rate>
    <camera>
      <horizontal_fov>1.5708</horizontal_fov>
      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>
      <clip>
        <near>0.01</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>true</always_on>
    <visualize>false</visualize>
  </sensor>
</gazebo>
    
    <!-- ========================= Transmissions ========================= -->

    <transmission name="body_lidar_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="lidar_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="body_lidar_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <!--  Front Left  -->

    <transmission name="hub_frontLeft_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="hub_frontLeft_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="hub_frontLeft_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <transmission name="wheel_frontLeft_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="wheel_frontLeft_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="wheel_frontLeft_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <!--  Front Right  -->
    
    <transmission name="hub_frontRight_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="hub_frontRight_joint" >
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="hub_frontRight_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <transmission name="wheel_frontRight_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="wheel_frontRight_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="wheel_frontRight_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <!--  Rear  -->

    <transmission name="wheel_rearLeft_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="wheel_rearLeft_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="wheel_rearLeft_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <transmission name="wheel_rearRight_tran">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="wheel_rearRight_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="wheel_rearRight_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
</robot>
